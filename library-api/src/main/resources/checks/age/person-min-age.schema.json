{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Input schema template for person-min-age check. Verifies a person's age meets a minimum threshold.",
  "properties": {
    "situation": {
      "type": "object",
      "properties": {
        "people": {
          "type": "object",
          "properties": {
            "{personId}": {
              "type": "object",
              "description": "A person whose age will be checked",
              "properties": {
                "dateOfBirth": {
                  "type": "string",
                  "format": "date",
                  "description": "The person's date of birth in ISO 8601 format (YYYY-MM-DD)"
                }
              },
              "required": ["dateOfBirth"]
            }
          }
        }
      },
      "required": ["people"]
    },
    "parameters": {
      "type": "object",
      "description": "Check parameters",
      "properties": {
        "personId": {
          "type": "string",
          "description": "ID of the person to check (must match a key in situation.people)"
        },
        "minAge": {
          "type": "number",
          "description": "The minimum age required (in years)"
        },
        "asOfDate": {
          "type": "string",
          "format": "date",
          "description": "The date to calculate age as of (defaults to today if not provided)"
        }
      },
      "required": ["personId", "minAge"]
    }
  },
  "required": ["situation", "parameters"]
}

  <dmn:decision id="_93A3B85E-B4D0-458A-B419-FA9EC7BC6104" name="checkResult">
    <dmn:extensionElements/>
    <dmn:variable id="_5CE656D7-E5AE-4CDD-B1C5-074F8FE0F812" name="checkResult" typeRef="boolean"/>
    <dmn:informationRequirement id="_9164FE76-0C6C-4D96-9CBD-5EC2639D22A8">
      <dmn:requiredInput href="#_222EBF53-16BF-4A13-A424-0AD32C90100D"/>
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_669BFE51-E50C-444C-853C-D6F45C4869F3">
      <dmn:requiredInput href="#_7E377FA3-246D-4CBF-AE45-3A3AFDB7372B"/>
    </dmn:informationRequirement>
    <dmn:context id="_328D3A06-BD36-4427-939D-0FB36593C608">
      <dmn:contextEntry>
        <dmn:variable id="_E2462CB0-9EFD-40FE-A3B4-06EE907F04C1" name="enrollments" typeRef="Any"/>
        <dmn:literalExpression id="_B4D6998E-CCE5-46D5-B4E6-98BACA83B869">
          <dmn:text>if parameters.personId != null then
  get value(situation.people, parameters.personId).enrollments
else
  null</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:literalExpression id="_70A20ADA-3C41-41E1-8D99-C8C39C6C7C23">
          <dmn:text>if enrollments != null and count(enrollments) != 0 then
  some benefit in enrollments satisfies benefit = parameters.benefit
else
  null</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
    </dmn:context>
  </dmn:decision>

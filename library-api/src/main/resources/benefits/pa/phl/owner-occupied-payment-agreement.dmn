    <dmn:informationRequirement id="_C1856599-71C6-45C0-8A41-1E34A63B95CC">
      <dmn:requiredDecision href="#_35D25C30-BCDF-461F-A570-9167E0660358"/>
    </dmn:informationRequirement>
    <dmn:context id="_D853AA71-6E4B-4236-A352-DC088C7BB8C5">
      <dmn:contextEntry>
        <dmn:variable id="_F979EE5C-BDEA-45D9-89CB-044FC3026395" name="checksAsList" typeRef="BDT.tBooleanList"/>
        <dmn:literalExpression id="_F0B360C9-5D8E-410A-A9DF-8BD44F4809D0">
          <dmn:text>// e.g. [true, false, true, null, ...]
for check in (get entries(checks))
return
  check.value</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_7547DF56-2600-4E9F-8C21-1C2BF650A433" name="result" typeRef="boolean"/>
        <dmn:literalExpression id="_95E8FD15-06BE-4BA0-A7C5-6F8397F705F9">
          <dmn:text>// true if all checks are true
// null if there are any null checks
// false if any check is false
all(checksAsList)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:literalExpression id="_D6B69CE5-0952-49E2-B2A4-6DC0806D7D7D">
          <dmn:text>result</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
    </dmn:context>
  </dmn:decision>

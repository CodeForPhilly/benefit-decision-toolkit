meta {
  name: NOT Enrolled in Bogus Benefit
  type: http
  seq: 1
}

post {
  url: {{host}}/checks/enrollment/person-not-enrolled-in-benefit
  body: json
  auth: inherit
}

body:json {
  {
    "situation": {
      "people": {
        "p1": {
          "enrollments": ["different_benefit"]
        },
        "p2": {
          "enrollments": ["bogus"]
        }
      }
    },
    "parameters": {
      "personId": "p1",
      "benefit": "bogus"
    }
  }
}

assert {
  res.body.checkResult: eq true
}

settings {
  encodeUrl: true
  timeout: 0
}
